    "admin_dashboard": {
      "structure": "Sidebar (Fixed Left) + Header (Top) + Main Content (Scrollable)",
      "grid": "grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6",
      "card_style": "bg-white border border-slate-200 shadow-sm hover:shadow-md transition-shadow duration-200"
    },
    "mobile_worker_app": {
      "structure": "Full height flex-col + Bottom Navigation (Sticky)",
      "padding": "px-4 py-6",
      "touch_targets": "min-h-[48px]",
      "card_style": "bg-white border border-slate-100 shadow-sm rounded-xl mb-4"
    }
